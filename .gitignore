# =============================================
#  Laravel 12 + Inertia/React + Engine Modules
#  .gitignore — Professional Best Practices
# =============================================

# ───── Dependencies ─────
/vendor/
/node_modules/
/engine/modules/*/vendor/
/engine/modules/*/node_modules/

# ───── Environment & Secrets (CRITICAL) ─────
.env
.env.*
!.env.example
/auth.json

# ───── Security — Keys & Certificates ─────
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
!package-lock.json.key
/storage/app/keys/

# ───── Laravel Framework Cache ─────
/bootstrap/cache/*.php
/storage/pail/

# ───── Database ─────
/database/*.sqlite*

# ───── Build & Compiled Assets ─────
/public/build/
/public/hot
/public/storage
/public/assets/
/public/www/
/public/themes/

# ───── SSR ─────
/bootstrap/ssr/
/storage/framework/views/*.php

# ───── Testing ─────
/.phpunit.cache/
.phpunit.result.cache
/coverage/

# ───── IDE / Editor ─────
/.fleet/
/.idea/
/.nova/
/.vscode/
/.zed/
/.cursor/
/.claude/
.continue/
.phpactor.json
_ide_helper*.php
.phpstorm.meta.php

# ───── OS Files ─────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ───── Temp / Unsafe ─────
*.log
*.tmp
*.bak
*.swp
*.swo
*~
*.cache

# ───── Docker / Sail ─────
/docker-compose.override.yml

# ───── Homestead / Vagrant ─────
Homestead.json
Homestead.yaml

# ───── FreeFileSync ─────
*.ffs_lock
*.ffs_tmp
sync.ffs_db

# ───── Binaries (safety net) ─────
*.exe
*.dll
*.so
*.dylib
