{
    "preset": "laravel",
    "rules": {
        "simplified_null_return": true,
        "fully_qualified_strict_types": true,
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha",
            "imports_order": ["const", "class", "function"]
        },
        "global_namespace_import": {
            "import_classes": true,
            "import_constants": false,
            "import_functions": false
        },

        "no_whitespace_in_blank_line": true,

        "trailing_comma_in_multiline": {
            "elements": ["arguments", "arrays", "match", "parameters"]
        },
        "method_chaining_indentation": true,
        "array_indentation": true,

        "class_attributes_separation": {
            "elements": {
                "const": "one",
                "method": "one",
                "property": "one"
            }
        },
        "ordered_class_elements": {
            "order": [
                "use_trait",
                "case",
                "constant_public",
                "constant_protected",
                "constant_private",
                "property_public_static",
                "property_protected_static",
                "property_private_static",
                "property_public",
                "property_protected",
                "property_private",
                "construct",
                "method_public_static",
                "method_protected_static",
                "method_private_static",
                "method_public",
                "method_protected",
                "method_private",
                "magic"
            ]
        },
        "protected_to_private": false,

        "lambda_not_used_import": true,
        "nullable_type_declaration_for_default_null_value": true,

        "yoda_style": false,
        "ternary_to_null_coalescing": true,
        "no_useless_return": true,

        "modernize_types_casting": true,
        "integer_literal_case": true,

        "single_line_empty_body": true,

        "phpdoc_order": {
            "order": ["param", "return", "throws"]
        },
        "phpdoc_no_empty_return": true,
        "phpdoc_types_order": {
            "null_adjustment": "always_last",
            "sort_algorithm": "alpha"
        },
        "no_superfluous_phpdoc_tags": {
            "allow_mixed": true,
            "remove_inheritdoc": false
        }
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "node_modules",
        "vendor",
        "public",
        "database/migrations",
        "database/seeds",
        "database/factories",
        "engine/themes/backend/system/public",
        "engine/themes/frontend/system/public",
        "engine/themes/core/system/public",
        "engine/themes/frontend/techwind/public",
        "engine/themes/backend/techwind/public",
        "engine/themes/core/techwind/public",
        "*.blade.php"
    ]
}
